# Tavily Search API Key (Required for live web research)
TAVILY_API_KEY=your_tavily_api_key_here

# LLM Providers (Provide at least one for live LLM reasoning, or leave blank/use "mock" for Mock Mode)
# Option A: Google Gemini (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional LLM Model Configurations (Defaults are used if left blank)
# GEMINI_MODEL=gemini-1.5-flash  # e.g., switch to gemini-2.0-flash or gemini-2.5-flash if needed
# GEMINI_API_VERSION=v1         # e.g., set to v1 if v1beta throws 404
# OPENAI_MODEL=gpt-4o-mini
